# Database Configuration
DATABASE_URL=postgresql://minirag:minirag123@localhost:5432/minirag

# LLaMA Server Configuration
LLAMA_SERVER_URL=http://localhost:8080
MODEL_PATH=./data/models/qwen2.5-7b-instruct-q4_k_m.gguf
# Имя файла GGUF в data/models (используется docker-compose). Задаётся автоматически
# командой `make download-model MODEL=qwen|mistral|llama3|llama2` (по умолч. llama3).
MODEL_FILE=qwen2.5-7b-instruct-q4_k_m.gguf
# Тюнинг llama-server (контекст/параллелизм/слои GPU) задаётся в docker-compose.yml
# (N_CTX, N_PARALLEL, N_GPU_LAYERS), а не здесь.

# LLM Backend для агентного графа: llama | anthropic | openai
# llama — локальный llama.cpp (по умолчанию, без ключей).
# anthropic/openai — облако, нужен соответствующий ключ.
LLM_BACKEND=llama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini

# Оценка качества (Ragas, eval/run_ragas.py). Судья по умолчанию = LLM_BACKEND.
# RAGAS_JUDGE: local | openai | anthropic | gemini | groq — чем судить метрики.
# groq — бесплатный tier, ключ gsk_... с console.groq.com (быстро, без карты).
# gemini — нужен Google AI Studio с billing (free tier в ряде регионов = 0).
RAGAS_JUDGE=local
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# System Prompt Configuration
SYSTEM_PROMPT_FILE=./prompts/mini-rag-system-prompt.txt

# Vector Store Configuration
VECTOR_STORE_TYPE=pgvector
EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_DIMENSION=384

# Redis Configuration
REDIS_URL=redis://localhost:6379

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# RAG Configuration
MAX_CONTEXT_CHUNKS=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Search Configuration
SIMILARITY_THRESHOLD=0.7
MAX_SEARCH_RESULTS=10 